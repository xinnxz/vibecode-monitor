# ============================================================
# SomniaScan — Smart Contracts Environment Variables
# Salin file ini ke .env dan isi nilainya
# JANGAN commit .env ke Git!
# ============================================================

# Private key wallet untuk deploy (tanpa prefix 0x)
# Dapatkan dari MetaMask: Settings > Account Details > Export Private Key
PRIVATE_KEY=your_private_key_here_no_0x_prefix

# Somnia Testnet RPC (default sudah di hardhat.config.js, bisa override di sini)
SOMNIA_RPC_URL=https://dream-rpc.somnia.network

# Etherscan / Explorer API Key (untuk verify contract di Shannon Explorer)
# Cek apakah Shannon Explorer (https://shannon.somnia.network/) mendukung API verify
EXPLORER_API_KEY=optional_if_supported
