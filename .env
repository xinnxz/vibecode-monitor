NEXT_PUBLIC_ALERT_ENGINE_ADDRESS=
NEXT_PUBLIC_EVENT_AGGREGATOR_ADDRESS=
NEXT_PUBLIC_SCOPE_REGISTRY_ADDRESS=

# ---- FRONTEND ----
NEXT_PUBLIC_SOMNIA_RPC=https://dream-rpc.somnia.network
NEXT_PUBLIC_CHAIN_ID=50312